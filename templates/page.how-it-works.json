{"sections":{"main":{"type":"page-content__main","disabled":true,"settings":{"show_heading":true,"heading_alignment":"left","width":"standard","padding_top":40,"padding_bottom":40,"css_class":"","custom_css":""}},"35dafb10-f7de-492e-b461-2a583e32f79f":{"type":"index__image-with-text-overlay","settings":{"link":"","image":"shopify:\/\/shop_images\/3_2.png","pretext":"","title":"Changing the lives of diabetics one innovative sock at a time","subtitle":"","pretext_color":"#000000","heading_color":"#ffffff","subheading_color":"#000000","text_alignment":"left","text_horizontal_position":"left","text_vertical_position":"middle","background_color":"rgba(0,0,0,0)","background_opacity":0,"border_color":"rgba(0,0,0,0)","border_width":0,"text_width":40,"button_1":"","button_1_link":"","button_1_style":"button--secondary","button_2":"","button_2_link":"","button_2_style":"button--secondary","mobile_image_crop":"none","mobile_text_below_image":true,"pretext_color_mobile":"#282121","heading_color_mobile":"#282121","subheading_color_mobile":"#282121","width":"wide","padding_top":0,"padding_bottom":0,"padding_left":0,"padding_right":0,"animation":"none","css_class":"top-banner-extend-overlay-text","custom_css":""}},"b48d6b1f-7be4-4108-b0ec-2a15988308f4":{"type":"index__icon-with-text-column","blocks":{"template--17297763008798__b48d6b1f-7be4-4108-b0ec-2a15988308f4-1671662674a4bf156a-0":{"type":"logo_image","settings":{"icon_label":"new-check","title":"Circulight® Infrared Technology","text":"<p>Designed in partnership with our team of scientists, doctors and engineers, Circufiber socks feature  Circulight® IR technology to improve circulation in your feet and lower legs.<\/p>","button_label":"","link":""}},"template--17297763008798__b48d6b1f-7be4-4108-b0ec-2a15988308f4-1671662674a4bf156a-1":{"type":"logo_image","settings":{"icon_label":"moisture-badge","title":"Moisture Wicking Fabric","text":"<p>Wicking socks work by pulling moisture away from your feet and into the surface of the sock. This prevents sweaty feet inside your shoes, giving you a much more pleasant day!<\/p>","button_label":"","link":""}},"template--17297763008798__b48d6b1f-7be4-4108-b0ec-2a15988308f4-1671662674a4bf156a-2":{"type":"logo_image","settings":{"icon_label":"usa-badge","title":"Designed <br>& Made in USA","text":"<p>Circufiber products are designed and made in the USA. We make them here because we believe in making the highest quality socks where we can control all aspects of the manufacturing process.<\/p>","button_label":"","link":""}}},"block_order":["template--17297763008798__b48d6b1f-7be4-4108-b0ec-2a15988308f4-1671662674a4bf156a-0","template--17297763008798__b48d6b1f-7be4-4108-b0ec-2a15988308f4-1671662674a4bf156a-1","template--17297763008798__b48d6b1f-7be4-4108-b0ec-2a15988308f4-1671662674a4bf156a-2"],"settings":{"icons_per_row":3,"icon_size":"large","align_text":"left","button_style":"button--primary","icon_color":"rgba(0,0,0,0)","text_color":"rgba(0,0,0,0)","background":"rgba(0,0,0,0)","gradient":"rgba(0,0,0,0)","gradient_rotation":0,"width":"standard","show_gutter":true,"padding_top":20,"padding_bottom":20,"padding_left":0,"padding_right":0,"animation":"none","css_class":"circufiber-selling-features","custom_css":""}},"0f45e8c5-effd-4c51-9df7-ab3d3413d5b0":{"type":"index__image-with-text","blocks":{"template--17297763008798__0f45e8c5-effd-4c51-9df7-ab3d3413d5b0-16716624412be69a0e-2":{"type":"text","settings":{"title":"Powered By Circulight® Infrared (IR)Technology","heading_size":"regular","text":"<p>Designed in partnership with our team of scientists, doctors and engineers, Circufiber socks feature our patent pending Circulight® IR technology to improve circulation in your feet and lower legs.<\/p>","button_label":"Shop Now","link":"shopify:\/\/pages\/ourcollections","button_style":"button--primary","background":"rgba(0,0,0,0)","text_color":"rgba(0,0,0,0)","alignment":"left","vertical_position":"center"}},"template--17297763008798__0f45e8c5-effd-4c51-9df7-ab3d3413d5b0-16716624412be69a0e-0":{"type":"image","settings":{"image":"shopify:\/\/shop_images\/Circufiber_January_Post-2v2_f425f27b-4f37-4a77-b410-59b27362af7c.gif","image_crop":"none","image_link":""}}},"block_order":["template--17297763008798__0f45e8c5-effd-4c51-9df7-ab3d3413d5b0-16716624412be69a0e-2","template--17297763008798__0f45e8c5-effd-4c51-9df7-ab3d3413d5b0-16716624412be69a0e-0"],"settings":{"width":"standard","show_gutter":true,"padding_top":20,"padding_bottom":20,"animation":"none","css_class":"","custom_css":""}},"024d09de-d2ca-45f2-988e-c6ec6909cf44":{"type":"index__image-with-text","blocks":{"template--17297763008798__024d09de-d2ca-45f2-988e-c6ec6909cf44-16716624412be69a0e-0":{"type":"image","settings":{"image":"shopify:\/\/shop_images\/Circufiber_January_Post-3.png","image_crop":"none","image_link":""}},"template--17297763008798__024d09de-d2ca-45f2-988e-c6ec6909cf44-16716624412be69a0e-2":{"type":"text","settings":{"title":"","heading_size":"regular","text":"<p>Circulight® IR technology is a proprietary blend of thermo-reactive minerals that when incorporated into our products, works with your body's energy to produce healing infrared light.<br\/><\/p><p>The human body naturally emits heat. Circulight® IR technology absorbs this heat and re-emits back into the body in the form of infrared light.<\/p><p>Tissues and cells absorb the infrared light, triggering the release of Nitric Oxide (NO) and the natural process of vasodilation.<br\/><\/p><p>We embed the minerals into the yarns themselves, making Circulight® IR virtually indestructible! While no socks last forever, Circulight® IR won't wash out or wear out, giving you the same benefits each and every time.<\/p>","button_label":"","link":"","button_style":"button--primary","background":"rgba(0,0,0,0)","text_color":"rgba(0,0,0,0)","alignment":"left","vertical_position":"center"}}},"block_order":["template--17297763008798__024d09de-d2ca-45f2-988e-c6ec6909cf44-16716624412be69a0e-0","template--17297763008798__024d09de-d2ca-45f2-988e-c6ec6909cf44-16716624412be69a0e-2"],"settings":{"width":"standard","show_gutter":true,"padding_top":20,"padding_bottom":20,"animation":"none","css_class":"","custom_css":""}},"904a5fad-aa51-4d3f-b951-2a693cc0ca4e":{"type":"index__rich-text","settings":{"title":"","heading_font":"open_sans_n4","heading_color":"rgba(0,0,0,0)","heading_alignment":"center","heading_size":30,"text":"<p>Circufiber® socks are designed for people at risk of or living with diabetes. Conditions and risks associated with diabetes vary across individuals and change over time. Always consult your healthcare professional to determine the best foot care products and treatment for your feet and condition.<\/p><p>Circufiber® socks powered by Circulight® IR technology can help people who are committed to improving their health through diet and exercise and are intended to promote a temporary increase in local blood circulation. <\/p><p>Additionally, our padding technology has been clinically shown to reduce pain, blisters, moisture and pressures. Our socks may also promote physical activity, which may, as a part of a healthy lifestyle:<\/p>","text_font":"open_sans_n4","text_color":"rgba(0,0,0,0)","text_alignment":"left","text_size":17,"columns":1,"button_label":"","button_link":"","button_alignment":"center","button_style":"button--primary","background":"rgba(0,0,0,0)","gradient":"rgba(0,0,0,0)","gradient_rotation":180,"width":"standard","padding_top":20,"padding_bottom":0,"padding_left":0,"padding_right":0,"animation":"none","css_class":"","custom_css":""}},"21498b5f-55b8-4238-8f85-2d0561ccaeda":{"type":"index__rich-text","settings":{"title":"","heading_font":"open_sans_n4","heading_color":"rgba(0,0,0,0)","heading_alignment":"center","heading_size":30,"text":"<ul><li>Enhance recovery from exercise<\/li><li>Help reduce the risk of high blood pressure<\/li><li>Improve physical fitness<\/li><li>Increase energy<br\/><\/li><\/ul>","text_font":"open_sans_n4","text_color":"rgba(0,0,0,0)","text_alignment":"left","text_size":17,"columns":1,"button_label":"Shop Now","button_link":"shopify:\/\/pages\/ourcollections","button_alignment":"left","button_style":"button--primary","background":"rgba(0,0,0,0)","gradient":"rgba(0,0,0,0)","gradient_rotation":180,"width":"standard","padding_top":0,"padding_bottom":0,"padding_left":0,"padding_right":0,"animation":"none","css_class":"","custom_css":".card-content {\npadding: 0px;\n}\n\ndiv.columns {\nmargin-bottom: 1.25rem;\n}"}},"facdb50e-4861-4e06-b251-cd2e9d1987b7":{"type":"index__image-with-text-overlay","settings":{"link":"","image":"shopify:\/\/shop_images\/5_bea459a3-d89c-49dd-8d83-72ad5ceadfe3.png","mobile_image":"shopify:\/\/shop_images\/1_62774a07-1cf6-43b5-a231-3b9509a992d6.png","pretext":"","title":"YALE TRIAL","subtitle":"","pretext_color":"#000000","heading_color":"#ffffff","subheading_color":"#000000","text_alignment":"left","text_horizontal_position":"left","text_vertical_position":"middle","background_color":"rgba(0,0,0,0)","background_opacity":0,"border_color":"rgba(0,0,0,0)","border_width":0,"text_width":40,"button_1":"","button_1_link":"","button_1_style":"button--secondary","button_2":"","button_2_link":"","button_2_style":"button--secondary","mobile_image_crop":"none","mobile_text_below_image":false,"pretext_color_mobile":"rgba(0,0,0,0)","heading_color_mobile":"rgba(0,0,0,0)","subheading_color_mobile":"rgba(0,0,0,0)","width":"standard","padding_top":0,"padding_bottom":0,"padding_left":0,"padding_right":0,"animation":"none","css_class":"","custom_css":""}},"e5b29e1c-22b3-4925-ab4a-db5dbf445d78":{"type":"index__rich-text","settings":{"title":"","heading_font":"open_sans_n4","heading_color":"rgba(0,0,0,0)","heading_alignment":"left","heading_size":30,"text":"<p>We believe that our patent pending technology can help people living with diabetes. That's why we have partnered with one of the most respected research universities in the world to gather the scientific data to prove it.<br\/><br\/>A clinical trial to study the benefits of Circufiber® socks is currently being conducted at Yale University. We believe the data will prove scientifically that our Circulight® IR Technology improves local circulation in the lower leg and feet in diabetic patients. The trial was developed and is being conducted by Adam Mayerson, M.D., a leading endocrinologist and Associate Chief of Medicine at Yale New Haven Hospital. Check back for updates and results.<\/p>","text_font":"open_sans_n4","text_color":"rgba(0,0,0,0)","text_alignment":"left","text_size":17,"columns":1,"button_label":"Shop Now","button_link":"shopify:\/\/pages\/ourcollections","button_alignment":"left","button_style":"button--primary","background":"rgba(0,0,0,0)","gradient":"rgba(0,0,0,0)","gradient_rotation":180,"width":"standard","padding_top":0,"padding_bottom":0,"padding_left":0,"padding_right":0,"animation":"none","css_class":"","custom_css":""}},"33793be6-1d91-436b-b68c-b898ee841e2c":{"type":"index__image-with-text-overlay","settings":{"link":"","image":"shopify:\/\/shop_images\/3_3.png","mobile_image":"shopify:\/\/shop_images\/2_8478f66e-d430-4727-951c-47db7b90cd59.png","pretext":"","title":"FDA","subtitle":"","pretext_color":"#000000","heading_color":"#ffffff","subheading_color":"#000000","text_alignment":"left","text_horizontal_position":"left","text_vertical_position":"middle","background_color":"rgba(0,0,0,0)","background_opacity":0,"border_color":"rgba(0,0,0,0)","border_width":0,"text_width":40,"button_1":"","button_1_link":"","button_1_style":"button--secondary","button_2":"","button_2_link":"","button_2_style":"button--secondary","mobile_image_crop":"none","mobile_text_below_image":false,"pretext_color_mobile":"rgba(0,0,0,0)","heading_color_mobile":"rgba(0,0,0,0)","subheading_color_mobile":"rgba(0,0,0,0)","width":"standard","padding_top":0,"padding_bottom":0,"padding_left":0,"padding_right":0,"animation":"none","css_class":"","custom_css":""}},"49e983e2-401a-4a5c-bc4d-da3f13576e25":{"ty