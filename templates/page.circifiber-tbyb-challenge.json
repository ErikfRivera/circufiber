_images\/Calendar_3x_0540e5a6-3389-4719-a171-2400801cd116.png","title":"Try For 2 Weeks","paratext":"<p>Wear your socks for 6+ hours a day every day for at least 2 weeks. Wash socks as needed.<\/p>\n\n<br>\n<p> You have an additional 3 days after the 2 week challenge to make a decision<\/p>"}},"f2e1f14d-25d2-4305-b183-2a2ac4f0c153":{"type":"logo_image","settings":{"icon_img":"shopify:\/\/shop_images\/Pain_Reduction_3x_51edcdca-593f-4aa7-ba9a-c1b16a86434e.png","title":"Love Them? Keep Them!","paratext":"<p>If you're satisfied with your purchase, no action is required.<\/p>\n\n<br> \n\n<p>Your $5 deposit will be applied as a credit towards your purchase and payment will be processed on day 17.<\/p>"}},"7f0b81ad-7441-4c94-88b2-9bb7cf562e49":{"type":"logo_image","settings":{"icon_img":"shopify:\/\/shop_images\/Pain_Reduction_copy_2_3x_d571b0aa-315f-4caf-826c-f10edb2bc76c.png","title":"Free Returns","paratext":"<p>Not 100% satisfied? Initiate a return up to 3 days after you've completed your 2-week challenge (before day 17). <\/p>\n\n<br> \n\n<p>You will receive a prepaid returns shipping label and your $5 deposit will be refunded as soon as your return is processed. <\/p>"}}},"block_order":["3caa4c94-7923-48ec-af13-9f862618c239","25f0f115-7d03-4ceb-b608-85bf086cd137","f2e1f14d-25d2-4305-b183-2a2ac4f0c153","7f0b81ad-7441-4c94-88b2-9bb7cf562e49"],"settings":{"css_class":"","main_subtitle":"","main_heading":"","background-color":"#d1e5f1","text-color":"#0a3a5b"}},"d5c2a703-029d-4149-93d4-6f0be7f9565f":{"type":"index__image-with-text","blocks":{"template--16852848640221__d5c2a703-029d-4149-93d4-6f0be7f9565f-text-1":{"type":"text","settings":{"title":"","heading_size":"regular","text":"","button_label":"Try Circufiber Socks for Free!","link":"shopify:\/\/collections\/circufiber-challenge-socks-tbyb","button_style":"button--primary","background":"rgba(0,0,0,0)","text_color":"rgba(0,0,0,0)","alignment":"center","vertical_position":"center"}}},"block_order":["template--16852848