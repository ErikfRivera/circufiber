<script>
  var swatchoption = document.querySelectorAll("a.swatch_option_color");
  for (var i = 0; i < swatchoption.length; i++) {
    swatchoption[i].addEventListener('click', (e)=>{
      e.preventDefault();
      let myElement = e.target;
      while (myElement.tagName !== 'A') {
        myElement = myElement.parentElement;
      } 
      var classname = myElement.getAttribute('data-swatch-name');    
      //console.log(myElement.closest(".product__thumbnail")  );  

      var fourChildNode = myElement.closest(".product__thumbnail").querySelectorAll('.'+ classname+' img ' );

        var myNodeList = myElement.closest(".product__thumbnail").querySelectorAll('img' );
        var divs = myNodeList ;

        for (var i = 0; i < divs.length; ++i) {
          var classlist = divs[i].getAttribute("class") 
          let classlist_new = classlist.replace("swap--visible", "-");
          divs[i].setAttribute("class", classlist_new+" swap--visible" );
        }  

        for (var i = 0; i < 1; ++i) {
          var classlist = fourChildNode[i].getAttribute("class") 
          let classlist_new = classlist.replace("swap--visible", "-");
          console.log(classlist_new);
          fourChildNode[i].setAttribute("class", classlist_new  );
        } 

    });    
}
</script>